# FILE: .env.example
# MODULE: Environment Variables für Docker Compose

# Database
DB_NAME=trueangels
DB_USER=admin
DB_PASSWORD=CHANGE_ME_SECURE_PASSWORD
DB_HOST=postgres
DB_PORT=5432

# Redis
REDIS_PASSWORD=CHANGE_ME_REDIS_PASSWORD

# API
SECRET_KEY=CHANGE_ME_SECRET_KEY_32_CHARS_MIN
ENVIRONMENT=production
API_VERSION=v1

# Stripe
STRIPE_SECRET_KEY=sk_live_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx
STRIPE_PUBLIC_KEY=pk_live_xxx

# PayPal
PAYPAL_CLIENT_ID=xxx
PAYPAL_CLIENT_SECRET=xxx
PAYPAL_MODE=live

# Klarna
KLARNA_USERNAME=xxx
KLARNA_PASSWORD=xxx
KLARNA_MODE=live

# Social Media
TWITTER_API_KEY=xxx
TWITTER_API_SECRET=xxx
TWITTER_BEARER_TOKEN=xxx

FACEBOOK_APP_ID=xxx
FACEBOOK_APP_SECRET=xxx

LINKEDIN_CLIENT_ID=xxx
LINKEDIN_CLIENT_SECRET=xxx

# Wasabi S3
WASABI_ACCESS_KEY=xxx
WASABI_SECRET_KEY=xxx
WASABI_BUCKET_NAME=trueangels-backups
WASABI_ENDPOINT=https://s3.wasabisys.com

# HashiCorp Vault
VAULT_TOKEN=xxx
VAULT_ADDR=http://vault:8200

# Monitoring
GRAFANA_PASSWORD=CHANGE_ME_GRAFANA

# Email (SendGrid/SMTP)
SMTP_HOST=smtp.sendgrid.net
SMTP_PORT=587
SMTP_USER=apikey
SMTP_PASSWORD=xxx
SMTP_FROM=noreply@trueangels.de