# FILE: .env.example
# TrueAngels NGO Suite v3.0 - Environment Variablen

# ==================== Basis Konfiguration ====================
ENVIRONMENT=development
DEBUG=true
SECRET_KEY=your-super-secret-key-change-in-production

# ==================== Datenbank ====================
DB_HOST=postgres
DB_PORT=5432
DB_NAME=trueangels
DB_USER=admin
DB_PASSWORD=change_me_secure_password

# ==================== Redis ====================
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=change_me_redis_password
REDIS_DB=0

# ==================== Stripe ====================
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_PUBLIC_KEY=pk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx

# ==================== PayPal ====================
PAYPAL_CLIENT_ID=xxx
PAYPAL_CLIENT_SECRET=xxx
PAYPAL_MODE=sandbox

# ==================== Klarna ====================
KLARNA_USERNAME=xxx
KLARNA_PASSWORD=xxx
KLARNA_MODE=sandbox

# ==================== Wasabi S3 ====================
WASABI_ACCESS_KEY=xxx
WASABI_SECRET_KEY=xxx
WASABI_BUCKET_NAME=trueangels-backups
WASABI_ENDPOINT=https://s3.wasabisys.com

# ==================== HashiCorp Vault ====================
VAULT_ADDR=http://vault:8200
VAULT_TOKEN=xxx

# ==================== Email (SendGrid) ====================
SMTP_HOST=smtp.sendgrid.net
SMTP_PORT=587
SMTP_USER=apikey
SMTP_PASSWORD=SG.xxx
SMTP_FROM=noreply@trueangels.de

# ==================== Telegram ====================
TELEGRAM_BOT_TOKEN=xxx
TELEGRAM_CHAT_ID=xxx

# ==================== Transparenz ====================
TRANSPARENCY_SALT=trueangels_salt_2024
TRANSPARENCY_CACHE_TTL=300

# ==================== Monitoring ====================
SENTRY_DSN=https://xxx@sentry.io/xxx
PROMETHEUS_ENABLED=true
OTEL_ENABLED=false
OTEL_EXPORTER_ENDPOINT=http://tempo:4318/v1/traces

# ==================== Logging ====================
LOG_LEVEL=INFO
LOG_FORMAT=json