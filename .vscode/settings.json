{
    // ==================== Python Interpreter ====================
    "python.defaultInterpreterPath": "${workspaceFolder}/.venv/bin/python",
    "ruff.path": "${workspaceFolder}/.venv/Scripts/ruff.exe",
    "python.terminal.activateEnvironment": true,
    // ==================== Ruff (Linting & Formatting) ====================
    "ruff.enable": true,
    "ruff.lint.enable": true,
    // ==================== Black (Fallback Formatierung) ====================
    "black-formatter.args": [
        "--line-length",
        "100"
    ],
    "black-formatter.path": [
        "${workspaceFolder}/.venv/bin/black"
    ],
    // ==================== MyPy (Type Checking) ====================
    "mypy-type-checker.args": [
        "--strict",
        "--ignore-missing-imports",
        "--follow-imports=silent"
    ],
    "mypy-type-checker.reportingScope": "file",
    // ==================== Pylance (Language Server) ====================
    "python.analysis.typeCheckingMode": "basic",
    "python.analysis.autoImportCompletions": true,
    "python.analysis.extraPaths": [
        "${workspaceFolder}/src"
    ],
    "python.analysis.diagnosticMode": "workspace",
    "python.analysis.diagnosticSeverityOverrides": {
        "reportMissingImports": "error",
        "reportUndefinedVariable": "error",
        "reportUnusedImport": "warning",
        "reportUnusedVariable": "warning",
        "reportGeneralTypeIssues": "information"
    },
    // ==================== Python Spezifisch ====================
    "[python]": {
        "editor.formatOnSave": true,
        "editor.defaultFormatter": "charliermarsh.ruff",
        "editor.codeActionsOnSave": {
            "source.fixAll.ruff": true, // ✅ Voll-auto
            "source.organizeImports.ruff": true // ✅ Imports sortieren
        },
        "editor.rulers": [
            100
        ],
        "editor.tabSize": 4
    },
    // ==================== TOML & YAML ====================
    "[toml]": {
        "editor.formatOnSave": true,
        "editor.defaultFormatter": "tamasfe.even-better-toml"
    },
    "[yaml]": {
        "editor.formatOnSave": true,
        "editor.defaultFormatter": "redhat.vscode-yaml"
    },
    "[json]": {
        "editor.formatOnSave": true
    },
    // ==================== Testing ====================
    "python.testing.pytestEnabled": true,
    "python.testing.pytestArgs": [
        "tests",
        "-v",
        "--tb=short"
    ],
    // ==================== Exclusions ====================
    "files.exclude": {
        "**/__pycache__": true,
        "**/.pytest_cache": true,
        "**/.mypy_cache": true,
        "**/.ruff_cache": true,
        "**/.coverage": true,
        "**/htmlcov": true
    },
    "files.watcherExclude": {
        "**/__pycache__/**": true,
        "**/.venv/**": true,
        "**/.git/**": true
    },
    // ==================== Problems Panel ====================
    "problems.defaultViewMode": "tree",
    "problems.showCurrentInStatus": true,
    "problems.sortOrder": "severity",
    // ==================== YAML Schema Association ====================
    "yaml.schemas": {
        "https://json.schemastore.org/dependabot-2.0.json": [
            ".github/dependabot.yml"
        ],
        "https://json.schemastore.org/github-workflow.json": [
            ".github/workflows/*.yml"
        ]
    },
    "yaml.validate": true,
    "yaml.format.enable": true
}